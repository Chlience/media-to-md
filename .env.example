# Media-to-MD optional environment overrides
# 推荐先复制 backend/config.example.json 为 backend/config.json；本文件只保留少量可选覆盖项。

# 前端连接后端的 API 地址。前端 Vite 启动/构建时读取 MEDIA_TO_MD_* 前缀变量。
MEDIA_TO_MD_API_BASE_URL=http://localhost:8000/api

# 可选：指定后端配置文件；留空会禁用 config.json 读取。
# WHISPERX_CONFIG_FILE=backend/config.json

# 可选：切换音视频转写执行方式。默认 cli；openai 会调用 whisperx-openai-server。
# WHISPERX_BACKEND=openai
# WHISPERX_CLI_MODEL=small
# WHISPERX_OPENAI_MODEL=large-v2
# WHISPERX_OPENAI_BASE_URL=http://localhost:9000/v1
# WHISPERX_OPENAI_API_KEY=change-me-if-server-requires-bearer
# WHISPERX_OPENAI_TIMEOUT_SECONDS=3600
# WHISPERX_CLI_ARGS_JSON={"batch_size":8,"compute_type":"default"}
# WHISPERX_OPENAI_ARGS_JSON={"batch_size":8}

# 可选：音视频转写和 OpenDataLoader PDF 共用的 LLM 润色服务。
# 任务级开关在工作台选择；这里控制供应商、模型和连接信息。
# LLM_POLISH_ENABLED=false
# LLM_POLISH_PROVIDER=openai
# LLM_POLISH_BASE_URL=https://api.openai.com/v1
# LLM_POLISH_API_KEY=change-me
# LLM_POLISH_MODEL=gpt-4o-mini
# LLM_POLISH_TIMEOUT_SECONDS=60

# 可选：本地启动前设置管理员初始账号；更推荐写入 backend/config.json。
# WHISPERX_ADMIN_USERNAME=admin
# WHISPERX_ADMIN_PASSWORD=change-me-before-use
