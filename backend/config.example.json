{
  "data_root": ".data/media-to-md",
  "whisperx_backend": "cli",
  "whisperx_openai_base_url": "http://localhost:9000/v1",
  "whisperx_openai_api_key": null,
  "whisperx_openai_timeout_seconds": 3600,
  "whisperx_cli_model": "small",
  "whisperx_openai_model": "large-v2",
  "whisperx_model_dir": ".data/models",
  "nltk_data_dir": ".data/models/nltk_data",
  "model_cache_only": false,
  "whisperx_cli_args": {
    "batch_size": 8,
    "compute_type": "default"
  },
  "whisperx_openai_args": {
    "batch_size": 8
  },
  "opendataloader_pdf_args": {
    "format": [
      "markdown",
      "text"
    ],
    "image_output": "off",
    "image_format": "png",
    "table_method": "default",
    "reading_order": "xycut",
    "threads": 1,
    "hybrid": "off"
  },
  "whisperx_llm_polish_enabled": false,
  "pdf_llm_polish_enabled": false,
  "llm_polish_provider": "openai",
  "llm_polish_base_url": null,
  "llm_polish_api_key": null,
  "llm_polish_model": null,
  "llm_polish_timeout_seconds": 60,
  "max_whisperx_upload_mb": 512,
  "max_pdf_upload_mb": 512,
  "admin_username": "admin",
  "admin_password": "change-me-before-use"
}
